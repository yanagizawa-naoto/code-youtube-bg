const original = fs.readFileSync(backupPath, 'utf8');
const patch = generatePatch({
  videos: [],
  transitions: [],
  opacity,
  switchInterval: 0,
  theme: 'glass',
  extensionPath: extRoot,
});

const stateUrl = `http://127.0.0.1:${serverPort}/state.json`;
const runtimePatch = `(function(){
var RUNTIME=${JSON.stringify(runtimeMarker)};
var stateUrl=${JSON.stringify(stateUrl)};
var currentKey='';
var wrap=null;
var frame=null;
var pendingFrame=null;
var pendingKey='';
var style=null;
function clamp(n,min,max){return Math.min(max,Math.max(min,n));}
function ensure(){
  if(!style){
    style=document.createElement('style');
    style.id='code-youtube-bg-live-css';
    document.head.appendChild(style);
  }
  if(!wrap){
    wrap=document.createElement('div');
    wrap.id='vscbg-wrap';
    wrap.style.cssText='position:fixed;inset:0;width:100vw;height:100vh;z-index:0;pointer-events:none;overflow:hidden;background:#000;';
    document.body.insertBefore(wrap,document.body.firstChild);
  }
}
function playerSrc(videoId,wantMuted,vol,key){
  var params=new URLSearchParams({
    v:videoId,
    token:key,
    muted:wantMuted?'1':'0',
    volume:String(clamp(vol,0,1)),
    _:String(Date.now())
  });
  return 'http://127.0.0.1:'+${JSON.stringify(serverPort)}+'/?'+params.toString();
}
function postCommand(f,func,args){
  try{
    if(f&&f.contentWindow){
      f.contentWindow.postMessage(JSON.stringify({event:'command',func:func,args:args||[]}), '*');
    }
  }catch(e){}
}
function applyFrameSettings(f,wantMuted,vol){
  if(!f)return;
  postCommand(f,'setVolume',[Math.round(clamp(vol,0,1)*100)]);
  if(wantMuted)postCommand(f,'mute',[]);
  else postCommand(f,'unMute',[]);
  postCommand(f,'playVideo',[]);
}
function cleanupFrame(f){
  if(!f)return;
  try{f.src='about:blank';}catch(e){}
  try{f.remove();}catch(e){}
}
function makeFrame(src,key){
  var f=document.createElement('iframe');
  f.className='code-youtube-bg-live-frame';
  f.dataset.key=key;
  f.src=src;
  f.title='YouTube background '+key;
  f.allow='autoplay; encrypted-media; picture-in-picture; fullscreen';
  f.setAttribute('allowfullscreen','');
  f.setAttribute('referrerpolicy','strict-origin-when-cross-origin');
  f.style.cssText='position:absolute;top:50%;left:50%;width:177.78vh;height:100vh;min-width:100vw;min-height:56.25vw;transform:translate(-50%,-50%);border:0;pointer-events:none;background:#000;opacity:1;transition:opacity .18s linear;';
  return f;
}
function promote(f,wantMuted,vol){
  if(!f)return;
  var key=f.dataset.key||'';
  if(key!==pendingKey&&key!==currentKey)return;
  if(frame&&frame!==f){
    var old=frame;
    old.style.opacity='0';
    setTimeout(function(){cleanupFrame(old);},220);
  }
  if(pendingFrame&&pendingFrame!==f){
    cleanupFrame(pendingFrame);
  }
  frame=f;
  frame.id='code-youtube-bg-live-frame';
  frame.style.opacity='1';
  currentKey=key;
  pendingFrame=null;
  pendingKey='';
  applyFrameSettings(frame,wantMuted,vol);
}
function loadNextFrame(videoId,key,wantMuted,vol){
  if(currentKey===key&&frame){
    applyFrameSettings(frame,wantMuted,vol);
    return;
  }
  if(pendingKey===key&&pendingFrame){
    applyFrameSettings(pendingFrame,wantMuted,vol);
    return;
  }
  if(pendingFrame){
    cleanupFrame(pendingFrame);
  }
  var src=playerSrc(videoId,wantMuted,vol,key);
  var next=makeFrame(src,key);
  pendingFrame=next;
  pendingKey=key;
  next.style.opacity=frame?'0':'1';
  next.addEventListener('load',function(){
    applyFrameSettings(next,wantMuted,vol);
    setTimeout(function(){promote(next,wantMuted,vol);},250);
  },{once:true});
  wrap.appendChild(next);
  setTimeout(function(){applyFrameSettings(next,wantMuted,vol);},600);
  setTimeout(function(){promote(next,wantMuted,vol);},1500);
}
function liveCss(op,adaptive){
  if(!adaptive){
    return [
      'html,body{background:#000!important}',
      'body{position:relative!important}',
      '#vscbg-wrap{z-index:0!important}',
      '.monaco-workbench{position:relative!important;z-index:1!important;opacity:'+op+'!important}'
    ].join('');
  }
  var panel=clamp(op,0.62,0.98);
  var empty=clamp(op-0.38,0.12,0.70);
  var gutter=clamp(op-0.25,0.22,0.82);
  var floating=clamp(op+0.02,0.72,0.98);
  return [
    'html,body{background:#000!important}',
    'body{position:relative!important}',
    '#vscbg-wrap{z-index:0!important}',
    '.monaco-workbench{position:relative!important;z-index:1!important;opacity:1!important;background:transparent!important}',
    '.monaco-workbench .part.titlebar,.monaco-workbench .part.activitybar,.monaco-workbench .part.sidebar,.monaco-workbench .part.auxiliarybar,.monaco-workbench .part.panel,.monaco-workbench .part.statusbar{background:rgba(18,18,18,'+panel+')!important}',
    '.monaco-workbench .part.editor{background:rgba(0,0,0,'+empty+')!important}',
    '.editor-group-container,.editor-container,.editor-instance,.monaco-editor,.monaco-editor-background,.monaco-editor .overflow-guard,.terminal-wrapper,.terminal-instance,.xterm,.xterm-viewport,.xterm-screen{background:transparent!important}',
    '.monaco-editor .margin,.monaco-editor .glyph-margin,.monaco-editor .line-numbers{background:rgba(0,0,0,'+gutter+')!important}',
    '.monaco-editor .view-lines,.monaco-editor .view-line,.xterm-rows,.xterm-rows>div{background:transparent!important}',
    '.quick-input-widget,.monaco-dialog-box,.monaco-menu-container,.context-view,.notifications-toasts .notification-toast,.monaco-hover{background:rgba(24,24,24,'+floating+')!important;backdrop-filter:blur(12px)}',
    '.monaco-list-row.focused,.monaco-list-row.selected,.monaco-list-row:hover,.monaco-tree-row.focused,.monaco-tree-row.selected,.monaco-tree-row:hover{background:rgba(70,110,170,.32)!important}'
  ].join('');
}
function applyState(state){
  if(!state||!state.videoId)return;
  ensure();
  var op=Number(state.opacity);
  if(!isFinite(op))op=${JSON.stringify(opacity)};
  op=clamp(op,0,1);
  style.textContent=liveCss(op,state.adaptive!==false);
  var vol=Number(state.volume);
  if(!isFinite(vol))vol=${JSON.stringify(volume)};
  var wantMuted=state.muted!==false;
  var key=String(state.mediaToken||state.updatedAt||state.videoId);
  loadNextFrame(state.videoId,key,wantMuted,vol);
}
function poll(){
  fetch(stateUrl+'?_='+Date.now(),{cache:'no-store'})
    .then(function(r){return r.ok?r.json():null;})
    .then(applyState)
    .catch(function(){});
}
function kick(){
  if(frame)postCommand(frame,'playVideo',[]);
  if(pendingFrame)postCommand(pendingFrame,'playVideo',[]);
}
function start(){
  poll();
  setTimeout(poll,250);
  setTimeout(poll,1000);
  setInterval(poll,1000);
  setInterval(function(){
    fetch(stateUrl+'?_='+Date.now(),{cache:'no-store'})
      .then(function(r){return r.ok?r.json():null;})
      .then(function(s){
        if(!s)return;
        var vol=Number(s.volume);
        if(!isFinite(vol))vol=${JSON.stringify(volume)};
        var wantMuted=s.muted!==false;
        applyFrameSettings(frame,wantMuted,vol);
      })
      .catch(function(){});
  },3000);
  document.addEventListener('visibilitychange',poll);
  window.addEventListener('focus',poll);
  window.addEventListener('pointerdown',kick,true);
  window.addEventListener('keydown',kick,true);
}
if(document.body){start();}
else{document.addEventListener('DOMContentLoaded',start);}
})();`;

fs.writeFileSync(jsPath, applyPatch(original, `${patch}\n${runtimePatch}`), 'utf8');

console.log('needs_restart=1');
