    video_format_selector='bv*[ext=mp4][vcodec^=avc1][protocol=https]/bv*[ext=mp4][vcodec^=avc1][protocol^=http]/bv*[ext=mp4][protocol=https]/bv*[ext=mp4][protocol^=http]/bestvideo[ext=mp4][protocol^=http]/best[ext=mp4][protocol^=http]/best'
    audio_format_selector='ba[ext=m4a][protocol=https]/ba[ext=m4a][protocol^=http]/ba[protocol=https]/ba[protocol^=http]/bestaudio[protocol^=http]/bestaudio/best'
  else
    video_format_selector='bv*[protocol=https][vcodec!=none]/bv*[protocol^=http][vcodec!=none]/bestvideo[protocol^=http]/best[protocol^=http]/best'
    audio_format_selector='ba[ext=m4a][protocol=https]/ba[ext=m4a][protocol^=http]/ba[protocol=https]/ba[protocol^=http]/bestaudio[protocol^=http]/bestaudio/best'
  fi
  ytdlp_stream_err="$user_data/yt-dlp-stream.err"

  resolve_ytdlp_url() {
    local selector="$1"
    local label="$2"
    local output=""
    local ytdlp_args=(
      --no-playlist
      --quiet
      --no-warnings
      -f "$selector"
      -g
      "$video_url"
    )

    if ! output="$("$ytdlp_bin" "${ytdlp_args[@]}" 2>"$ytdlp_stream_err")"; then
      local cookies_browser="${CODE_YOUTUBE_BG_COOKIES_FROM_BROWSER:-chrome}"
      if [[ -n "$cookies_browser" && "$cookies_browser" != "0" ]]; then
        echo "yt-dlp needs browser cookies for $label; retrying with --cookies-from-browser $cookies_browser" >&2
        if ! output="$("$ytdlp_bin" --cookies-from-browser "$cookies_browser" "${ytdlp_args[@]}" 2>>"$ytdlp_stream_err")"; then
          cat "$ytdlp_stream_err" >&2 || true
          exit 1
        fi
      else
        cat "$ytdlp_stream_err" >&2 || true
        exit 1
      fi
    fi

    printf '%s\n' "$output" | sed -n '1p'
  }

  stream_url="$(resolve_ytdlp_url "$video_format_selector" "video")"
  audio_stream_url=""
  if [[ "$audio_enabled" == "1" && "$mux_source_mode" != "single" ]]; then
    audio_stream_url="$(resolve_ytdlp_url "$audio_format_selector" "audio")"
  fi

  if [[ "$stream_url" != https://* ]]; then
    echo "Failed to resolve a usable HTTPS stream URL" >&2
    exit 1
  fi

  muxed_audio_enabled=0
  if [[ "$audio_enabled" == "1" && "$audio_engine" == "inline" ]]; then
