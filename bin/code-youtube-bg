function patchWorkbenchHtmlForStream() {
  if (!fs.existsSync(htmlBackupPath)) {
    fs.copyFileSync(htmlPath, htmlBackupPath);
  }

  let html = fs.readFileSync(htmlBackupPath, 'utf8');
  html = html.replace(
