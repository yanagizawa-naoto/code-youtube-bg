function bufferedText(){
  if(!video||!video.buffered)return '';
  var out=[];
  try{
    for(var i=0;i<video.buffered.length;i++){
      out.push(video.buffered.start(i).toFixed(2)+'-'+video.buffered.end(i).toFixed(2));
    }
  }catch(e){}
  return out.join(',');
}
function reportDebug(reason){
  if(!video)return;
  var body={
    runtime:RUNTIME,
    reason:reason||'tick',
    key:currentKey,
    src:currentSrc,
    videoId:lastState&&lastState.videoId||'',
    audioMode:lastState&&lastState.audioMode||'',
    inlineAudio:lastState&&lastState.inlineAudio===true,
    paused:video.paused,
    ended:video.ended,
    muted:video.muted,
    volume:video.volume,
    readyState:video.readyState,
    networkState:video.networkState,
    currentTime:video.currentTime,
    duration:isFinite(video.duration)?video.duration:null,
    playbackRate:video.playbackRate,
    videoWidth:video.videoWidth,
    videoHeight:video.videoHeight,
    buffered:bufferedText(),
    audioTracks:video.audioTracks?video.audioTracks.length:null,
    webkitAudioDecodedByteCount:typeof video.webkitAudioDecodedByteCount==='number'?video.webkitAudioDecodedByteCount:null,
    webkitVideoDecodedByteCount:typeof video.webkitVideoDecodedByteCount==='number'?video.webkitVideoDecodedByteCount:null,
    error:video.error?{code:video.error.code,message:video.error.message||''}:null,
    playError:playError
  };
  try{
    fetch(debugUrl,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body),keepalive:true}).catch(function(){});
  }catch(e){}
}
function roundedRect(ctx,x,y,w,h,r){
  r=Math.max(0,Math.min(r,w/2,h/2));
  ctx.beginPath();
  ctx.moveTo(x+r,y);
  ctx.lineTo(x+w-r,y);
  ctx.quadraticCurveTo(x+w,y,x+w,y+r);
  ctx.lineTo(x+w,y+h-r);
  ctx.quadraticCurveTo(x+w,y+h,x+w-r,y+h);
  ctx.lineTo(x+r,y+h);
  ctx.quadraticCurveTo(x,y+h,x,y+h-r);
  ctx.lineTo(x,y+r);
  ctx.quadraticCurveTo(x,y,x+r,y);
  ctx.closePath();
}
function clearShade(){
  if(!shadeCanvas)return;
  var ctx=shadeCanvas.getContext('2d');
  if(ctx)ctx.clearRect(0,0,shadeCanvas.width,shadeCanvas.height);
}
function scheduleShade(){
  if(!adaptiveUi){
    clearShade();
    return;
  }
  if(shadeRaf)return;
  shadeRaf=requestAnimationFrame(drawShade);
}
function shadeTargets(){
  return [
    '.monaco-editor .view-line',
    '.xterm-rows > div',
    '.monaco-list-row',
    '.monaco-tree-row',
    '.tabs-container .tab',
    '.monaco-breadcrumb-item',
    '.monaco-icon-label',
    '.action-label',
    '.monaco-button',
    '.monaco-inputbox',
    '.quick-input-widget',
    '.monaco-dialog-box',
    '.notification-toast',
    '.statusbar-item',
    '.part.sidebar .title',
    '.part.panel .title',
    '.part.auxiliarybar .title',
    '.editor-instance img',
    '.editor-instance canvas:not(#vscbg-readability-canvas)',
    '.editor-instance iframe',
    '.webview',
    '.image-preview'
  ].join(',');
}
function drawShade(){
  shadeRaf=0;
  if(!adaptiveUi||!shadeCanvas){
    clearShade();
    return;
  }
  var width=window.innerWidth||document.documentElement.clientWidth||1;
  var height=window.innerHeight||document.documentElement.clientHeight||1;
  var dpr=Math.max(1,Math.min(2,window.devicePixelRatio||1));
  var pixelWidth=Math.max(1,Math.floor(width*dpr));
  var pixelHeight=Math.max(1,Math.floor(height*dpr));
  if(shadeCanvas.width!==pixelWidth||shadeCanvas.height!==pixelHeight){
    shadeCanvas.width=pixelWidth;
    shadeCanvas.height=pixelHeight;
  }
  var ctx=shadeCanvas.getContext('2d');
  if(!ctx)return;
  ctx.setTransform(dpr,0,0,dpr,0,0);
  ctx.clearRect(0,0,width,height);
  var alpha=clamp(currentOpacity-0.16,0.32,0.78);
  var strongAlpha=clamp(currentOpacity-0.08,0.42,0.86);
  var nodes=[];
  try{nodes=Array.prototype.slice.call(document.querySelectorAll(shadeTargets()));}catch(e){nodes=[];}
  var count=0;
  for(var i=0;i<nodes.length&&count<360;i++){
    var node=nodes[i];
    if(!node||node.id==='vscbg-readability-canvas'||node.closest&&node.closest('#vscbg-wrap'))continue;
    var text=(node.textContent||'').replace(/\\s+/g,'').trim();
    var media=node.tagName==='IMG'||node.tagName==='IFRAME'||node.tagName==='CANVAS'||String(node.className||'').indexOf('webview')!==-1||String(node.className||'').indexOf('image-preview')!==-1;
    if(!media&&!text&&!(node.classList&&node.classList.contains('monaco-inputbox')))continue;
    var rects=[];
    try{rects=Array.prototype.slice.call(node.getClientRects());}catch(e){rects=[];}
    for(var r=0;r<rects.length&&count<360;r++){
      var rect=rects[r];
      if(!rect||rect.width<3||rect.height<3)continue;
      if(rect.bottom<0||rect.top>height||rect.right<0||rect.left>width)continue;
      var isLarge=rect.width>width*0.92&&rect.height>height*0.35;
      if(isLarge&&!media)continue;
      var padX=media?10:6;
      var padY=media?8:2;
      var x=Math.max(0,rect.left-padX);
      var y=Math.max(0,rect.top-padY);
      var w=Math.min(width-x,rect.width+padX*2);
      var h=Math.min(height-y,rect.height+padY*2);
      ctx.fillStyle='rgba(0,0,0,'+(media?strongAlpha:alpha)+')';
      roundedRect(ctx,x,y,w,h,media?8:4);
      ctx.fill();
      count++;
    }
  }
}
function applyVideoSettings(wantMuted,vol){
  if(!video)return;
  var nextVol=Number(vol);
  if(!isFinite(nextVol))nextVol=0;
  desiredMuted=!!wantMuted;
  desiredVolume=clamp(nextVol,0,1);
  video.volume=desiredMuted?0:desiredVolume;
  video.dataset.wantMuted=desiredMuted?'1':'0';
  video.muted=desiredMuted;
  video.loop=true;
  video.autoplay=true;
}
function forceStartAtZero(reason){
  if(!video||!currentKey||startAtZeroKey!==currentKey||video.readyState<1)return;
  try{
    video.currentTime=0;
    startAtZeroKey='';
    reportDebug(reason||'start-zero');
  }catch(e){}
}
function kickVideo(){
  if(!video)return;
  var wantsSound=!desiredMuted&&desiredVolume>0;
  var startMuted=wantsSound&&video.paused;
  video.muted=startMuted?true:desiredMuted;
  video.volume=startMuted?0:(desiredMuted?0:desiredVolume);
  var played;
  try{played=video.play();}catch(e){playError=String(e&&e.message||e);reportDebug('play-throw');return;}
  if(played&&typeof played.then==='function'){
    played.then(function(){
      if(wantsSound){
        video.muted=false;
        video.volume=desiredVolume;
      }
      playError='';
      reportDebug('play-ok');
    }).catch(function(e){playError=String(e&&e.message||e);reportDebug('play-rejected');});
  }
}
function kick(){
  kickVideo();
}
function setVideoRate(rate){
  if(!video)return;
  var next=Number(rate);
  if(!isFinite(next))next=1;
  next=clamp(next,0.96,1.04);
  if(Math.abs(next-1)<0.003)next=1;
  try{
    if(Math.abs(video.playbackRate-next)>0.002){
      video.playbackRate=next;
    }
  }catch(e){}
}
function applySync(payload){
  if(!video||!lastState||lastState.audioSync!=='server-mpv'){
    setVideoRate(1);
    return;
  }
  var audio=payload&&payload.audio||{};
  if(!audio.running){
    setVideoRate(1);
    return;
  }
  var expectedMediaKey=String(lastState.mediaToken||lastState.updatedAt||lastState.videoId||'');
  if(audio.mediaKey&&String(audio.mediaKey)!==expectedMediaKey){
    setVideoRate(1);
    return;
  }
  if(startAtZeroKey===currentKey){
    forceStartAtZero('start-zero-sync');
    setVideoRate(1);
    return;
  }
  var issued=Number(audio.targetIssuedAt)||0;
  var target=Number(audio.targetVideoTime);
  if(issued&&issued!==lastSyncTargetIssuedAt&&isFinite(target)&&video.readyState>=1){
    lastSyncTargetIssuedAt=issued;
    if(Math.abs(video.currentTime-target)>0.9){
      try{
        video.currentTime=Math.max(0,target);
        reportDebug('sync-video-seek');
      }catch(e){}
    }
  }
  setVideoRate(audio.recommendedVideoRate);
}
function pollSync(){
  fetch(syncUrl+'?_='+Date.now(),{cache:'no-store'})
    .then(function(r){return r.ok?r.json():null;})
    .then(applySync)
    .catch(function(){});
}
function reloadCurrentVideo(delay){
  if(!video||!currentSrc)return;
  if(retryTimer)clearTimeout(retryTimer);
  retryTimer=setTimeout(function(){
    if(!video||!currentSrc)return;
    applyVideoSettings(desiredMuted,desiredVolume);
    try{video.pause();}catch(e){}
    try{video.removeAttribute('src');video.load();}catch(e){}
    video.src=cacheBust(currentSrc);
    try{video.load();}catch(e){}
    kickVideo();
    setTimeout(kickVideo,500);
  },delay||0);
}
function loadNextVideo(nextSrc,nextKey,wantMuted,vol){
  nextKey=nextKey||nextSrc;
  ensure();
  applyVideoSettings(wantMuted,vol);
  if(currentKey===nextKey&&currentSrc===nextSrc){
    kickVideo();
    return;
  }
  setVideoRate(1);
  lastSyncTargetIssuedAt=0;
  currentKey=nextKey;
  currentSrc=nextSrc;
  startAtZeroKey=nextKey;
  video.muted=desiredMuted;
  video.volume=desiredMuted?0:desiredVolume;
  try{video.pause();}catch(e){}
  try{video.removeAttribute('src');video.load();}catch(e){}
  video.src=nextSrc;
  try{video.load();}catch(e){}
  forceStartAtZero('start-zero-load');
  setTimeout(function(){forceStartAtZero('start-zero-50');},50);
  setTimeout(function(){forceStartAtZero('start-zero-250');},250);
  setTimeout(function(){forceStartAtZero('start-zero-750');},750);
  kickVideo();
  setTimeout(kickVideo,300);
  setTimeout(kickVideo,900);
  setTimeout(kickVideo,1800);
}
function liveCss(op,adaptive){
  if(!adaptive){
    return [
      'html,body{background:#000!important}',
      'body{position:relative!important}',
      '#vscbg-wrap{z-index:0!important}',
      '#vscbg-readability-canvas{display:none!important}',
      '.monaco-workbench{position:relative!important;z-index:1!important;opacity:'+op+'!important}'
    ].join('');
  }
  var panel=clamp(op,0.62,0.98);
  var empty=clamp(op-0.38,0.12,0.70);
  var gutter=clamp(op-0.25,0.22,0.82);
  var floating=clamp(op+0.02,0.72,0.98);
  return [
    'html,body{background:#000!important}',
    'body{position:relative!important}',
    '#vscbg-wrap{z-index:0!important}',
    '#vscbg-readability-canvas{display:block!important}',
    '.monaco-workbench{position:relative!important;z-index:1!important;opacity:1!important;background:transparent!important}',
    '.monaco-workbench .part.titlebar,.monaco-workbench .part.activitybar,.monaco-workbench .part.sidebar,.monaco-workbench .part.auxiliarybar,.monaco-workbench .part.panel,.monaco-workbench .part.statusbar{background:rgba(18,18,18,'+panel+')!important}',
    '.monaco-workbench .part.editor{background:rgba(0,0,0,'+empty+')!important}',
    '.editor-group-container,.editor-container,.editor-instance,.monaco-editor,.monaco-editor-background,.monaco-editor .overflow-guard,.terminal-wrapper,.terminal-instance,.xterm,.xterm-viewport,.xterm-screen{background:transparent!important}',
    '.monaco-editor .margin,.monaco-editor .glyph-margin,.monaco-editor .line-numbers{background:rgba(0,0,0,'+gutter+')!important}',
    '.monaco-editor .view-lines,.monaco-editor .view-line,.xterm-rows,.xterm-rows>div{background:transparent!important}',
    '.tabs-container,.title.tabs,.breadcrumbs-below-tabs,.editor-group-watermark{background:rgba(0,0,0,'+empty+')!important}',
    '.quick-input-widget,.monaco-dialog-box,.monaco-menu-container,.context-view,.notifications-toasts .notification-toast,.monaco-hover{background:rgba(24,24,24,'+floating+')!important;backdrop-filter:blur(12px)}',
    '.monaco-list-row.focused,.monaco-list-row.selected,.monaco-list-row:hover,.monaco-tree-row.focused,.monaco-tree-row.selected,.monaco-tree-row:hover{background:rgba(70,110,170,.32)!important}',
    '.monaco-editor .current-line,.monaco-editor .view-overlays .current-line{background:rgba(255,255,255,.07)!important}'
  ].join('');
}
function applyState(state){
  if(!state||!state.src)return;
  lastState=state;
  ensure();
  var useMux=state.audioMode==='muxed'&&!!state.muxedProxySrc;
  var inlineAudio=state.inlineAudio===true;
  var nextSrc=useMux?state.muxedProxySrc:(state.proxySrc||state.src);
  var nextKey=String(state.mediaToken||state.updatedAt||nextSrc);
  if(useMux)nextKey='muxed:'+nextKey;
  var op=Number(state.opacity);
  var vol=Number(state.volume);
  if(!isFinite(vol))vol=${JSON.stringify(volume)};
  if(!isFinite(op))op=${JSON.stringify(opacity)};
  op=clamp(op,0,1);
  currentOpacity=op;
  adaptiveUi=state.adaptive!==false;
  style.textContent=liveCss(op,adaptiveUi);
  loadNextVideo(nextSrc,nextKey,!useMux||!inlineAudio,vol);
  scheduleShade();
  reportDebug('state');
}
function poll(){
  fetch(stateUrl+'?_='+Date.now(),{cache:'no-store'})
    .then(function(r){return r.ok?r.json():null;})
    .then(applyState)
    .catch(function(){});
}
function start(){
  poll();
  setTimeout(poll,250);
  setTimeout(poll,1000);
  setInterval(poll,1000);
  setInterval(pollSync,700);
  setInterval(kickVideo,1000);
  setInterval(function(){reportDebug('tick');},1500);
  setInterval(scheduleShade,500);
  document.addEventListener('visibilitychange',poll);
  document.addEventListener('scroll',scheduleShade,true);
  window.addEventListener('focus',poll);
  window.addEventListener('resize',scheduleShade);
  window.addEventListener('pointerdown',kick,true);
  window.addEventListener('keydown',kick,true);
  window.addEventListener('pointerdown',scheduleShade,true);
  window.addEventListener('keydown',scheduleShade,true);
}
if(document.body){start();}
else{document.addEventListener('DOMContentLoaded',start);}
})();`;

fs.writeFileSync(jsPath, applyPatch(original, `${patch}\n${runtimePatch}`), 'utf8');

console.log(`needs_restart=1`);
console.log(`html_changed=${htmlChanged ? 1 : 0}`);
console.log(`Streaming video live runtime installed for ${videoId}`);
NODE
)"

  printf '%s\n' "$patch_result" | sed '/^needs_restart=/d;/^html_changed=/d'
  needs_restart="$(printf '%s\n' "$patch_result" | sed -n 's/^needs_restart=//p' | tail -n 1)"
  html_changed="$(printf '%s\n' "$patch_result" | sed -n 's/^html_changed=//p' | tail -n 1)"

  start_bg_server
  if [[ "$audio_enabled" == "1" && "$audio_engine" == "mpv" ]]; then
    update_audio_player
  else
    stop_audio_player
  fi

  if [[ "$needs_restart" == "1" || "$html_changed" == "1" ]]; then
    codesign --force --deep --sign - "$app" >/dev/null
  fi

  app_running=0
  if is_code_video_bg_running; then
    app_running=1
  fi

  if [[ "$needs_restart" == "1" || "$html_changed" == "1" ]]; then
    stop_code_video_bg
    app_running=0
    start_bg_server
  fi

  if [[ "$app_running" == "0" ]]; then
    open -na "$app" --args \
      --user-data-dir "$user_data" \
      --extensions-dir "$extensions_dir" \
      --autoplay-policy=no-user-gesture-required \
      --password-store=basic \
      --use-mock-keychain \
      --new-window "$HOME"
    sleep 3
    echo "Code Video BG launched with streaming YouTube background: $video_url"
  else
    echo "Code Video BG live background updated without restart: $video_url"
  fi

  activate_code_video_bg

  stream_token="$(current_stream_token)"
  if ! verify_stream_not_rejected "$stream_token"; then
    if restore_previous_live_state; then
      echo "Playback check failed for $video_id; restored the previous background state." >&2
    else
      echo "Playback check failed for $video_id." >&2
    fi
    exit 1
  fi

  exit 0
fi

"$node_bin" - "$input" "$opacity" "$server_port" "$ext_root" "$js_path" "$backup_path" "$html_path" "$html_backup_path" "$state_path" <<'NODE'
const fs = require('fs');
const path = require('path');

const [input, opacityText, serverPortText, extRoot, jsPath, backupPath, htmlPath, htmlBackupPath, statePath] = process.argv.slice(2);
const opacity = Number(opacityText);
const serverPort = Number(serverPortText);

if (!Number.isFinite(opacity) || opacity < 0 || opacity > 1) {
  throw new Error(`Invalid CODE_YOUTUBE_BG_OPACITY: ${opacityText}`);
}

if (!Number.isInteger(serverPort) || serverPort < 1024 || serverPort > 65535) {
  throw new Error(`Invalid CODE_YOUTUBE_BG_PORT: ${serverPortText}`);
}

function extractVideoId(value) {
  const trimmed = String(value || '').trim();
  if (/^[A-Za-z0-9_-]{11}$/.test(trimmed)) return trimmed;

  let parsed;
  try {
    parsed = new URL(trimmed);
  } catch {
    throw new Error(`Not a YouTube URL or 11-character video ID: ${trimmed}`);
  }

  const host = parsed.hostname.replace(/^www\./, '');
  let id = null;

  if (host === 'youtu.be') {
    id = parsed.pathname.split('/').filter(Boolean)[0];
  } else if (host.endsWith('youtube.com') || host.endsWith('youtube-nocookie.com')) {
    id = parsed.searchParams.get('v');
    if (!id) {
      const parts = parsed.pathname.split('/').filter(Boolean);
      const marker = parts.findIndex(part => ['embed', 'shorts', 'live'].includes(part));
      if (marker !== -1) id = parts[marker + 1];
    }
  }

  if (!id || !/^[A-Za-z0-9_-]{11}$/.test(id)) {
    throw new Error(`Could not extract a YouTube video ID from: ${trimmed}`);
  }

  return id;
}

function youtubePatch(videoId) {
  const src = `http://127.0.0.1:${serverPort}/?v=${videoId}&_=${Date.now()}`;
  return `(function(){
var videoId=${JSON.stringify(videoId)};
var src=${JSON.stringify(src)};
var existing=document.getElementById('code-youtube-bg');
if(existing){ existing.remove(); }
var css=document.getElementById('code-youtube-bg-css');
if(!css){
  css=document.createElement('style');
  css.id='code-youtube-bg-css';
  document.head.appendChild(css);
}
css.textContent='html,body{background:#000!important}.code-youtube-bg-wrap{position:fixed;inset:0;width:100vw;height:100vh;z-index:0;pointer-events:none;overflow:hidden;background:#000}.code-youtube-bg-frame{position:absolute;top:50%;left:50%;width:177.78vh;height:100vh;min-width:100vw;min-height:56.25vw;transform:translate(-50%,-50%);border:0;pointer-events:none;background:#000}.monaco-workbench{position:relative!important;z-index:1!important}';
function postCommand(frame, func){
  try {
    if(frame && frame.contentWindow){
      frame.contentWindow.postMessage(JSON.stringify({event:'command',func:func,args:[]}), '*');
    }
  } catch(e) {}
}
function init(){
  var wrap=document.createElement('div');
  wrap.id='code-youtube-bg';
  wrap.className='code-youtube-bg-wrap';
  var frame=document.createElement('iframe');
  frame.className='code-youtube-bg-frame';
  frame.src=src;
  frame.title='YouTube background wrapper '+videoId;
  frame.allow='autoplay; encrypted-media; picture-in-picture; fullscreen';
  frame.setAttribute('allowfullscreen','');
  frame.setAttribute('referrerpolicy','strict-origin-when-cross-origin');
  wrap.appendChild(frame);
  document.body.insertBefore(wrap, document.body.firstChild);
  frame.addEventListener('load', function(){
    postCommand(frame, 'mute');
    postCommand(frame, 'playVideo');
  });
  setInterval(function(){
    postCommand(frame, 'mute');
    postCommand(frame, 'playVideo');
  }, 3000);
}
if(document.body){ init(); }
else{ document.addEventListener('DOMContentLoaded', init); }
})();`;
}

function patchWorkbenchHtml() {
  if (!fs.existsSync(htmlBackupPath)) {
    fs.copyFileSync(htmlPath, htmlBackupPath);
  }

  let html = fs.readFileSync(htmlBackupPath, 'utf8');
  html = html.replace(
    /frame-src\s+([\s\S]*?)\s+;/,
    `frame-src
\t\t\t\t\t'self'
\t\t\t\t\tvscode-webview:
\t\t\t\t\thttp://127.0.0.1:*
\t\t\t\t\thttp://localhost:*
\t\t\t\t\thttps://www.youtube.com
\t\t\t\t\thttps://www.youtube-nocookie.com
\t\t\t\t;`
  );
  fs.writeFileSync(htmlPath, html, 'utf8');
}

const videoId = extractVideoId(input);
const { generatePatch } = require(path.join(extRoot, 'out/patchGenerator.js'));
const { applyPatch } = require(path.join(extRoot, 'out/patchFile.js'));

patchWorkbenchHtml();

if (!fs.existsSync(backupPath)) {
  fs.copyFileSync(jsPath, backupPath);
}

