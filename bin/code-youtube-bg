  videoId,
  opacity,
  serverPort,
  wrapperUrl: `http://127.0.0.1:${serverPort}/`,
  updatedAt: new Date().toISOString(),
}, null, 2) + '\n');

console.log(`YouTube background set to ${videoId}`);
NODE

video_id="$("$node_bin" - "$state_path" <<'NODE'
const fs = require('fs');
