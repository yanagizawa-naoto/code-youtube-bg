  patch_result="$("$node_bin" - "$input" "$opacity" "$audio_enabled" "$volume" "$audio_delay" "$server_port" "$ext_root" "$js_path" "$backup_path" "$html_path" "$html_backup_path" "$state_path" "$live_state_path" "$stream_url" "$audio_stream_url" "$video_id" "$runtime_marker" "$muxed_audio_enabled" "$mux_container" "$mux_source_mode" "$audio_engine" "$adaptive" <<'NODE'
