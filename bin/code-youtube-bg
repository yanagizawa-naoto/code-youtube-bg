#!/usr/bin/env bash
set -euo pipefail

if [[ $# -lt 1 || "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  cat <<'USAGE'
Usage:
  code-youtube-bg [--local] [--audio|--mute] [--volume 0.7] [--audio-engine inline|mpv] [--audio-delay 0] <youtube-url-or-video-id>
  code-youtube-bg --stream [--audio|--mute] [--volume 0.7] [--audio-engine inline|mpv] [--audio-delay 0] <youtube-url-or-video-id>
  code-youtube-bg --embed <youtube-url-or-video-id>

Examples:
  code-youtube-bg https://www.youtube.com/watch?v=SjmWM9P5mZ8
  code-youtube-bg SjmWM9P5mZ8
  code-youtube-bg --stream --audio --volume 0.6 SjmWM9P5mZ8
  code-youtube-bg --embed SjmWM9P5mZ8

Modes:
  --local  Download/reuse a local MP4 and use it as the VS Code background. Default.
  --stream Resolve a temporary YouTube media stream URL and play it directly.
  --embed  Experimental YouTube iframe background. YouTube may block autoplay.

Environment:
  CODE_YOUTUBE_BG_OPACITY=0.75  # VS Code UI opacity, 0.0-1.0
  CODE_YOUTUBE_BG_PORT=45173    # Local temporary wrapper server port
  CODE_YOUTUBE_BG_AUDIO=0       # 1 enables audio by default
  CODE_YOUTUBE_BG_VOLUME=0.7    # Audio volume, 0.0-1.0
  CODE_YOUTUBE_BG_AUDIO_ENGINE=mpv     # mpv is auto-synced by the local server; inline is experimental
  CODE_YOUTUBE_BG_AUDIO_DELAY=0        # compatibility fallback only. Positive delays audio; negative advances audio.
  CODE_YOUTUBE_BG_ADAPTIVE=1           # 1 keeps text readable while empty editor space shows more video
  CODE_YOUTUBE_BG_COOKIES_FROM_BROWSER=chrome
  CODE_YOUTUBE_BG_FFMPEG=/opt/homebrew/bin/ffmpeg
USAGE
  exit 0
fi

mode="local"
audio_enabled="${CODE_YOUTUBE_BG_AUDIO:-0}"
audio_engine="${CODE_YOUTUBE_BG_AUDIO_ENGINE:-mpv}"
volume="${CODE_YOUTUBE_BG_VOLUME:-0.7}"
audio_delay="${CODE_YOUTUBE_BG_AUDIO_DELAY:-0}"
adaptive="${CODE_YOUTUBE_BG_ADAPTIVE:-1}"
args=()

while [[ $# -gt 0 ]]; do
  case "${1:-}" in
    --local)
      mode="local"
      shift
      ;;
    --stream)
      mode="stream"
      shift
      ;;
    --embed)
      mode="embed"
      shift
      ;;
    --audio)
      audio_enabled="1"
      shift
      ;;
    --mute|--muted)
      audio_enabled="0"
      shift
      ;;
    --volume)
      if [[ $# -lt 2 ]]; then
        echo "--volume requires a value from 0.0 to 1.0" >&2
        exit 1
      fi
      volume="$2"
      shift 2
      ;;
    --audio-engine)
      if [[ $# -lt 2 ]]; then
        echo "--audio-engine requires inline or mpv" >&2
        exit 1
      fi
      audio_engine="$2"
      shift 2
      ;;
    --audio-delay)
      if [[ $# -lt 2 ]]; then
        echo "--audio-delay requires a value in seconds, for example -0.2 or 0.2" >&2
        exit 1
      fi
      audio_delay="$2"
      shift 2
      ;;
    --)
      shift
      while [[ $# -gt 0 ]]; do
        args+=("$1")
        shift
      done
      ;;
    -*)
      echo "Unknown option: $1" >&2
      exit 1
      ;;
    *)
      args+=("$1")
      shift
      ;;
  esac
done

if [[ ${#args[@]} -lt 1 ]]; then
  echo "Missing YouTube URL or video ID" >&2
  exit 1
fi

input="${args[0]}"
opacity="${CODE_YOUTUBE_BG_OPACITY:-0.75}"
server_port="${CODE_YOUTUBE_BG_PORT:-45173}"
app="$HOME/Applications/Code Video BG.app"
user_data="$HOME/Library/Application Support/Code Video BG"
extensions_dir="$HOME/.vscode-video-bg/extensions"
download_dir="$user_data/youtube-videos"
ext_root="${CODE_YOUTUBE_BG_EXTENSION_ROOT:-}"
server_path="$HOME/.local/lib/code-youtube-bg/server.js"
server_label="com.naoto.code-youtube-bg.server"
audio_label="code-youtube-bg-audio"
node_bin="$(command -v node || true)"
ytdlp_bin="$(command -v yt-dlp || true)"
mpv_bin="$(command -v mpv || true)"
ffmpeg_bin="${CODE_YOUTUBE_BG_FFMPEG:-$(command -v ffmpeg || true)}"
js_path="$app/Contents/Resources/app/out/vs/workbench/workbench.desktop.main.js"
backup_path="$js_path.before-video-bg"
html_path="$app/Contents/Resources/app/out/vs/code/electron-browser/workbench/workbench.html"
html_backup_path="$html_path.before-youtube-bg"
state_path="$user_data/youtube-bg.json"
live_state_path="$user_data/live-state.json"
previous_live_state_path="$live_state_path.previous"
runtime_marker="code-youtube-bg-live-runtime.v23"
server_log_path="$user_data/youtube-bg-server.log"
server_err_path="$user_data/youtube-bg-server.err"
server_pid_path="$user_data/youtube-bg-server.pid"
server_plist_path="$user_data/code-youtube-bg-server.plist"
audio_log_path="$user_data/youtube-bg-audio.log"
audio_err_path="$user_data/youtube-bg-audio.err"
audio_ipc_path="$user_data/youtube-bg-audio.sock"

if [[ -z "$ext_root" ]]; then
  for candidate in \
    "$HOME"/.vscode/extensions/caoge.vscode-background-* \
    "$extensions_dir"/caoge.vscode-background-*; do
    if [[ -d "$candidate" ]]; then
      ext_root="$candidate"
      break
    fi
  done
fi

if [[ ! -d "$app" ]]; then
  echo "Code Video BG.app not found: $app" >&2
  exit 1
fi

if [[ ! -f "$js_path" ]]; then
  echo "VS Code workbench JS not found: $js_path" >&2
  exit 1
fi

if [[ ! -f "$html_path" ]]; then
  echo "VS Code workbench HTML not found: $html_path" >&2
  exit 1
fi

if [[ ! -d "$ext_root" ]]; then
  echo "Required extension files not found: $ext_root" >&2
  exit 1
fi

if [[ ! -f "$server_path" ]]; then
  echo "Local YouTube wrapper server not found: $server_path" >&2
  exit 1
fi

if [[ ! -x "$node_bin" ]]; then
  echo "node not found in PATH" >&2
  exit 1
fi

mkdir -p "$user_data" "$extensions_dir"

stop_code_video_bg() {
  osascript -e 'tell application id "com.naoto.CodeVideoBG" to quit' >/dev/null 2>&1 || true
  pkill -TERM -f "$app" 2>/dev/null || true
  pkill -TERM -f "$user_data" 2>/dev/null || true

  for _ in {1..30}; do
    if ! pgrep -f "$app" >/dev/null 2>&1 && ! pgrep -f "$user_data" >/dev/null 2>&1; then
      return 0
    fi
    sleep 0.2
  done

  pkill -KILL -f "$app" 2>/dev/null || true
  pkill -KILL -f "$user_data" 2>/dev/null || true
  sleep 0.5
}

is_code_video_bg_running() {
  if osascript -e 'application id "com.naoto.CodeVideoBG" is running' 2>/dev/null | grep -q true; then
    return 0
  fi

  pgrep -f "$app/Contents/MacOS/Code" >/dev/null 2>&1
}

activate_code_video_bg() {
  osascript \
    -e 'ignoring application responses' \
    -e 'tell application id "com.naoto.CodeVideoBG" to activate' \
    -e 'end ignoring' >/dev/null 2>&1 || true
}

start_bg_server() {
  local health=""
  health="$(curl -fsS "http://127.0.0.1:$server_port/health" 2>/dev/null || true)"
  if [[ "$health" == *"\"hasStatePath\":true"* && "$health" == *"\"serverVersion\":16"* ]]; then
    return 0
  fi

  launchctl bootout "gui/$(id -u)" "$server_plist_path" 2>/dev/null || true
  launchctl remove "$server_label" 2>/dev/null || true
  if [[ -f "$server_pid_path" ]]; then
    local old_server_pid=""
    old_server_pid="$(sed -n '1p' "$server_pid_path" 2>/dev/null || true)"
    if [[ "$old_server_pid" =~ ^[0-9]+$ ]]; then
      kill "$old_server_pid" 2>/dev/null || true
    fi
    rm -f "$server_pid_path"
  fi
  pkill -TERM -f "code-youtube-bg-server .* $server_port" 2>/dev/null || true

  for _ in {1..30}; do
    if ! pgrep -f "code-youtube-bg-server .* $server_port" >/dev/null 2>&1 && ! lsof -nP -iTCP:"$server_port" -sTCP:LISTEN >/dev/null 2>&1; then
      break
    fi
    sleep 0.1
  done
  : > "$server_log_path"
  : > "$server_err_path"

  local server_ready=0
  "$node_bin" - "$server_plist_path" "$server_label" "$node_bin" "$server_path" "$video_id" "$server_port" "$live_state_path" "$ffmpeg_bin" "$mpv_bin" "$audio_log_path" "$audio_err_path" "$audio_ipc_path" "$server_log_path" "$server_err_path" <<'NODE'
const fs = require('fs');
const [
  plistPath,
  label,
  nodeBin,
  serverPath,
  videoId,
  serverPort,
  liveStatePath,
  ffmpegBin,
  mpvBin,
  audioLogPath,
  audioErrPath,
  audioIpcPath,
  serverLogPath,
  serverErrPath,
] = process.argv.slice(2);

function esc(value) {
  return String(value)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&apos;');
}

function stringArray(values) {
  return `<array>\n${values.map(value => `\t\t<string>${esc(value)}</string>`).join('\n')}\n\t</array>`;
}

function envDict(values) {
  return `<dict>\n${Object.entries(values).map(([key, value]) => `\t\t<key>${esc(key)}</key>\n\t\t<string>${esc(value)}</string>`).join('\n')}\n\t</dict>`;
}

const xml = `<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
\t<key>Label</key>
\t<string>${esc(label)}</string>
\t<key>ProgramArguments</key>
\t${stringArray([nodeBin, serverPath, videoId, serverPort])}
\t<key>EnvironmentVariables</key>
\t${envDict({
  CODE_YOUTUBE_BG_STATE_PATH: liveStatePath,
  CODE_YOUTUBE_BG_FFMPEG: ffmpegBin,
  CODE_YOUTUBE_BG_MPV: mpvBin,
  CODE_YOUTUBE_BG_AUDIO_LOG: audioLogPath,
  CODE_YOUTUBE_BG_AUDIO_ERR: audioErrPath,
  CODE_YOUTUBE_BG_AUDIO_IPC: audioIpcPath,
})}
\t<key>RunAtLoad</key>
\t<true/>
\t<key>ProcessType</key>
\t<string>Background</string>
\t<key>StandardOutPath</key>
\t<string>${esc(serverLogPath)}</string>
\t<key>StandardErrorPath</key>
\t<string>${esc(serverErrPath)}</string>
</dict>
</plist>
`;
fs.writeFileSync(plistPath, xml, 'utf8');
NODE

  if ! launchctl bootstrap "gui/$(id -u)" "$server_plist_path" 2>>"$server_err_path"; then
    nohup /usr/bin/env CODE_YOUTUBE_BG_STATE_PATH="$live_state_path" \
      CODE_YOUTUBE_BG_FFMPEG="$ffmpeg_bin" \
      CODE_YOUTUBE_BG_MPV="$mpv_bin" \
      CODE_YOUTUBE_BG_AUDIO_LOG="$audio_log_path" \
      CODE_YOUTUBE_BG_AUDIO_ERR="$audio_err_path" \
      CODE_YOUTUBE_BG_AUDIO_IPC="$audio_ipc_path" \
      "$node_bin" "$server_path" "$video_id" "$server_port" \
      >>"$server_log_path" 2>>"$server_err_path" </dev/null &
    local new_server_pid="$!"
    printf '%s\n' "$new_server_pid" > "$server_pid_path"
    disown "$new_server_pid" 2>/dev/null || true
  else
    rm -f "$server_pid_path"
  fi

  for _ in {1..50}; do
    health="$(curl -fsS "http://127.0.0.1:$server_port/health" 2>/dev/null || true)"
    if [[ "$health" == *"\"hasStatePath\":true"* && "$health" == *"\"serverVersion\":16"* ]]; then
      server_ready=1
      break
    fi
    sleep 0.1
  done

  if [[ "$server_ready" != "1" ]]; then
    echo "Failed to start local YouTube background server on port $server_port" >&2
    tail -n 50 "$server_log_path" >&2 || true
    tail -n 50 "$server_err_path" >&2 || true
    exit 1
  fi
}

stop_audio_player() {
  launchctl remove "$audio_label" 2>/dev/null || true
  if [[ -x "$mpv_bin" ]]; then
    pkill -TERM -f "^$mpv_bin .*127\\.0\\.0\\.1:$server_port/audio" 2>/dev/null || true
    pkill -TERM -f "^$mpv_bin .*127\\.0\\.0\\.1:$server_port/mux" 2>/dev/null || true
    pkill -TERM -f "^$mpv_bin .*--title=code-youtube-bg-audio" 2>/dev/null || true
  fi
  rm -f "$audio_ipc_path"
}

update_audio_player() {
  stop_audio_player

  if [[ "$audio_enabled" != "1" ]]; then
    return 0
  fi

  if [[ ! -x "$mpv_bin" ]]; then
    echo "mpv not found; background audio disabled" >&2
    return 0
  fi

  : > "$audio_log_path"
  : > "$audio_err_path"
  return 0
}

current_stream_token() {
  if [[ ! -f "$live_state_path" ]]; then
    return 0
  fi

  "$node_bin" - "$live_state_path" <<'NODE'
const fs = require('fs');
try {
  const state = JSON.parse(fs.readFileSync(process.argv[2], 'utf8'));
  process.stdout.write(String(state.mediaToken || ''));
} catch (_) {}
NODE
}

verify_stream_not_rejected() {
  local expected_token="$1"
  local health=""
  local saw_rejection=0

  if [[ -z "$expected_token" ]]; then
    return 0
  fi

  for _ in {1..50}; do
    health="$(curl -fsS "http://127.0.0.1:$server_port/health" 2>/dev/null || true)"
    if [[ "$health" == *"\"key\":\"$expected_token\""* ]]; then
      if [[ "$health" == *"\"reason\":\"play-ok\""* ]]; then
        return 0
      fi
      if [[ "$health" == *"\"reason\":\"play-rejected\""* || "$health" == *"\"reason\":\"error\""* ]]; then
        saw_rejection=1
      fi
    fi
    sleep 0.2
  done

  if [[ "$saw_rejection" == "1" ]]; then
    return 1
  fi

  return 0
}

restore_previous_live_state() {
  if [[ -f "$previous_live_state_path" ]]; then
    cp -p "$previous_live_state_path" "$live_state_path"
    return 0
  fi

  return 1
}

video_meta="$("$node_bin" - "$input" <<'NODE'
const input = process.argv[2];

function extractVideoId(value) {
  const trimmed = String(value || '').trim();
  if (/^[A-Za-z0-9_-]{11}$/.test(trimmed)) return trimmed;

  let parsed;
  try {
    parsed = new URL(trimmed);
  } catch {
    throw new Error(`Not a YouTube URL or 11-character video ID: ${trimmed}`);
  }

  const host = parsed.hostname.replace(/^www\./, '');
  let id = null;

  if (host === 'youtu.be') {
    id = parsed.pathname.split('/').filter(Boolean)[0];
  } else if (host.endsWith('youtube.com') || host.endsWith('youtube-nocookie.com')) {
    id = parsed.searchParams.get('v');
    if (!id) {
      const parts = parsed.pathname.split('/').filter(Boolean);
      const marker = parts.findIndex(part => ['embed', 'shorts', 'live'].includes(part));
      if (marker !== -1) id = parts[marker + 1];
    }
  }

  if (!id || !/^[A-Za-z0-9_-]{11}$/.test(id)) {
    throw new Error(`Could not extract a YouTube video ID from: ${trimmed}`);
  }

  return id;
}

const videoId = extractVideoId(input);
process.stdout.write(`${videoId}\thttps://www.youtube.com/watch?v=${videoId}`);
NODE
)"
IFS=$'\t' read -r video_id video_url <<< "$video_meta"

if [[ "$audio_enabled" != "0" && "$audio_enabled" != "1" ]]; then
  echo "CODE_YOUTUBE_BG_AUDIO must be 0 or 1" >&2
  exit 1
fi

if [[ "$audio_engine" != "mpv" && "$audio_engine" != "inline" ]]; then
  echo "CODE_YOUTUBE_BG_AUDIO_ENGINE must be mpv or inline" >&2
  exit 1
fi

if [[ "$adaptive" != "0" && "$adaptive" != "1" ]]; then
  echo "CODE_YOUTUBE_BG_ADAPTIVE must be 0 or 1" >&2
  exit 1
fi

volume="$("$node_bin" - "$volume" <<'NODE'
const value = Number(process.argv[2]);
if (!Number.isFinite(value) || value < 0 || value > 1) {
  throw new Error('Volume must be a number from 0.0 to 1.0');
}
process.stdout.write(String(value));
NODE
)"

audio_delay="$("$node_bin" - "$audio_delay" <<'NODE'
const value = Number(process.argv[2]);
if (!Number.isFinite(value) || value < -10 || value > 10) {
  throw new Error('Audio delay must be a number from -10.0 to 10.0 seconds');
}
process.stdout.write(String(value));
NODE
)"

if [[ "$mode" == "local" ]]; then
  if [[ ! -x "$ytdlp_bin" ]]; then
    echo "yt-dlp not found in PATH" >&2
    exit 1
  fi

  mkdir -p "$download_dir"
  launchctl remove "$server_label" 2>/dev/null || true
  stop_code_video_bg

  echo "Downloading or reusing local MP4 for $video_id"
  video_path="$("$ytdlp_bin" \
    --no-playlist \
    --quiet \
    --no-warnings \
    --merge-output-format mp4 \
    -f 'bv*[ext=mp4][vcodec^=avc1]+ba[ext=m4a]/b[ext=mp4][vcodec^=avc1]/bv*+ba/best' \
    -P "$download_dir" \
    -o '%(title).120B [%(id)s].%(ext)s' \
    --print after_move:filepath \
    "$video_url")"

  if [[ ! -f "$video_path" ]]; then
    echo "Downloaded video file not found: $video_path" >&2
    exit 1
  fi

  "$node_bin" - "$input" "$opacity" "$audio_enabled" "$volume" "$ext_root" "$js_path" "$backup_path" "$state_path" "$video_path" "$video_id" <<'NODE'
const fs = require('fs');
const path = require('path');

const [input, opacityText, audioEnabledText, volumeText, extRoot, jsPath, backupPath, statePath, videoPath, videoId] = process.argv.slice(2);
const opacity = Number(opacityText);
const muted = audioEnabledText !== '1';
const volume = Number(volumeText);

if (!Number.isFinite(opacity) || opacity < 0 || opacity > 1) {
  throw new Error(`Invalid CODE_YOUTUBE_BG_OPACITY: ${opacityText}`);
}

const { generatePatch } = require(path.join(extRoot, 'out/patchGenerator.js'));
const { applyPatch } = require(path.join(extRoot, 'out/patchFile.js'));

if (!fs.existsSync(backupPath)) {
  fs.copyFileSync(jsPath, backupPath);
}

const original = fs.readFileSync(backupPath, 'utf8');
const patch = generatePatch({
  videos: [videoPath],
  transitions: ['instant'],
  opacity,
  switchInterval: 0,
  theme: 'glass',
  extensionPath: extRoot,
});
const keepPlayingPatch = `(function(){
function kickBackgroundVideos(){
  var videos=document.querySelectorAll('#vscbg-wrap video');
  for(var i=0;i<videos.length;i++){
    var v=videos[i];
    v.muted=${JSON.stringify(muted)};
    v.volume=${JSON.stringify(volume)};
    v.loop=true;
    v.autoplay=true;
    v.play().catch(function(){});
  }
}
setTimeout(kickBackgroundVideos,250);
setTimeout(kickBackgroundVideos,1000);
setInterval(kickBackgroundVideos,2000);
document.addEventListener('visibilitychange',kickBackgroundVideos);
window.addEventListener('focus',kickBackgroundVideos);
})();`;

fs.writeFileSync(jsPath, applyPatch(original, `${patch}\n${keepPlayingPatch}`), 'utf8');

fs.mkdirSync(path.dirname(statePath), { recursive: true });
fs.writeFileSync(statePath, JSON.stringify({
  type: 'local',
  input,
  videoId,
  opacity,
  muted,
  volume,
  localPath: videoPath,
  updatedAt: new Date().toISOString(),
}, null, 2) + '\n');

console.log(`Local video background set to ${videoPath}`);
NODE

  codesign --force --deep --sign - "$app" >/dev/null

  open -na "$app" --args \
    --user-data-dir "$user_data" \
    --extensions-dir "$extensions_dir" \
    --autoplay-policy=no-user-gesture-required \
    --password-store=basic \
    --use-mock-keychain \
    --new-window "$HOME"

  sleep 3
  activate_code_video_bg

  echo "Code Video BG launched with local YouTube background: $video_url"
  exit 0
fi

if [[ "$mode" == "stream" ]]; then
  if [[ "${CODE_YOUTUBE_BG_IFRAME:-0}" == "1" ]]; then
  patch_result="$("$node_bin" - "$input" "$opacity" "$audio_enabled" "$volume" "$server_port" "$ext_root" "$js_path" "$backup_path" "$html_path" "$html_backup_path" "$state_path" "$live_state_path" "$video_id" "$runtime_marker" "$adaptive" <<'NODE'
const fs = require('fs');
const path = require('path');

const [input, opacityText, audioEnabledText, volumeText, serverPortText, extRoot, jsPath, backupPath, htmlPath, htmlBackupPath, statePath, liveStatePath, videoId, runtimeMarker, adaptiveText] = process.argv.slice(2);
const opacity = Number(opacityText);
const muted = audioEnabledText !== '1';
const volume = Number(volumeText);
const serverPort = Number(serverPortText);
const adaptive = adaptiveText !== '0';

if (!Number.isFinite(opacity) || opacity < 0 || opacity > 1) {
  throw new Error(`Invalid CODE_YOUTUBE_BG_OPACITY: ${opacityText}`);
}

if (!Number.isFinite(volume) || volume < 0 || volume > 1) {
  throw new Error(`Invalid volume: ${volumeText}`);
}

if (!Number.isInteger(serverPort) || serverPort < 1024 || serverPort > 65535) {
  throw new Error(`Invalid CODE_YOUTUBE_BG_PORT: ${serverPortText}`);
}

function patchWorkbenchHtmlForIframe() {
  if (!fs.existsSync(htmlBackupPath)) {
    fs.copyFileSync(htmlPath, htmlBackupPath);
  }

  let html = fs.readFileSync(htmlBackupPath, 'utf8');
  html = html.replace(
    /frame-src\s+([\s\S]*?)\s+;/,
    `frame-src
\t\t\t\t\t'self'
\t\t\t\t\tvscode-webview:
\t\t\t\t\thttp://127.0.0.1:*
\t\t\t\t\thttp://localhost:*
\t\t\t\t\thttps://www.youtube.com
\t\t\t\t\thttps://www.youtube-nocookie.com
\t\t\t\t;`
  );
  html = html.replace(
    /connect-src\s+([\s\S]*?)\s+;/,
    `connect-src
\t\t\t\t\t'self'
\t\t\t\t\thttps:
\t\t\t\t\tws:
\t\t\t\t\thttp://127.0.0.1:*
\t\t\t\t\thttp://localhost:*
\t\t\t\t;`
  );
  const previous = fs.existsSync(htmlPath) ? fs.readFileSync(htmlPath, 'utf8') : '';
  if (previous !== html) {
    fs.writeFileSync(htmlPath, html, 'utf8');
    return true;
  }
  return false;
}

const { generatePatch } = require(path.join(extRoot, 'out/patchGenerator.js'));
const { applyPatch } = require(path.join(extRoot, 'out/patchFile.js'));

const htmlChanged = patchWorkbenchHtmlForIframe();
const mediaToken = `${Date.now()}-${videoId}`;

fs.mkdirSync(path.dirname(liveStatePath), { recursive: true });
fs.writeFileSync(liveStatePath, JSON.stringify({
  type: 'youtube-iframe',
  input,
  videoId,
  mediaToken,
  muted,
  volume,
  opacity,
  adaptive,
  serverPort,
  updatedAt: new Date().toISOString(),
}, null, 2) + '\n');

fs.mkdirSync(path.dirname(statePath), { recursive: true });
