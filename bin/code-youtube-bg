\t\t\t\t;`
  );
  html = html.replace(
    /connect-src\s+([\s\S]*?)\s+;/,
    `connect-src
\t\t\t\t\t'self'
\t\t\t\t\thttps:
\t\t\t\t\tws:
\t\t\t\t\thttp://127.0.0.1:*
\t\t\t\t\thttp://localhost:*
\t\t\t\t;`
  );
  const previous = fs.existsSync(htmlPath) ? fs.readFileSync(htmlPath, 'utf8') : '';
  if (previous !== html) {
    fs.writeFileSync(htmlPath, html, 'utf8');
    return true;
  }
  return false;
}

