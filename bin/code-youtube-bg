#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  code-youtube-bg [--embed] [--audio|--mute] [--volume 0.7] <youtube-url-or-video-id>

Examples:
  code-youtube-bg https://www.youtube.com/watch?v=SjmWM9P5mZ8
  code-youtube-bg https://www.youtube.com/playlist?list=PLxxxxxxxxxxxxxxxx
  code-youtube-bg SjmWM9P5mZ8
  code-youtube-bg --audio --volume 0.35 SjmWM9P5mZ8

Mode:
  This public build only uses YouTube's embeddable iframe player.
  It does not download videos or resolve direct media stream URLs.

Environment:
  CODE_YOUTUBE_BG_OPACITY=0.75  # VS Code UI opacity, 0.0-1.0
  CODE_YOUTUBE_BG_PORT=45173    # Local iframe wrapper server port
  CODE_YOUTUBE_BG_AUDIO=0       # 1 asks the YouTube iframe to unmute
  CODE_YOUTUBE_BG_VOLUME=0.7    # YouTube iframe volume, 0.0-1.0
USAGE
}

if [[ $# -lt 1 || "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

audio_enabled="${CODE_YOUTUBE_BG_AUDIO:-0}"
volume="${CODE_YOUTUBE_BG_VOLUME:-0.7}"
args=()

while [[ $# -gt 0 ]]; do
  case "${1:-}" in
    --embed)
      shift
      ;;
    --stream|--local)
      echo "$1 was removed from the public build." >&2
      echo "This build only uses YouTube's embeddable iframe player and does not download or resolve direct media URLs." >&2
      exit 2
      ;;
    --audio)
      audio_enabled="1"
      shift
      ;;
    --mute|--muted)
      audio_enabled="0"
      shift
      ;;
    --volume)
      if [[ $# -lt 2 ]]; then
        echo "--volume requires a value from 0.0 to 1.0" >&2
        exit 1
      fi
      volume="$2"
      shift 2
      ;;
    --audio-engine|--audio-delay)
      echo "$1 is not supported in the iframe-only public build." >&2
      exit 2
      ;;
    --)
      shift
      while [[ $# -gt 0 ]]; do
        args+=("$1")
        shift
      done
      ;;
    -*)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
    *)
      args+=("$1")
      shift
      ;;
  esac
done

if [[ ${#args[@]} -lt 1 ]]; then
  echo "Missing YouTube URL or video ID" >&2
  exit 1
fi

input="${args[0]}"
opacity="${CODE_YOUTUBE_BG_OPACITY:-0.75}"
server_port="${CODE_YOUTUBE_BG_PORT:-45173}"
debug_port="${CODE_YOUTUBE_BG_DEBUG_PORT:-9223}"
app="$HOME/Applications/Code Video BG.app"
user_data="$HOME/Library/Application Support/Code Video BG"
extensions_dir="$HOME/.vscode-video-bg/extensions"
server_path="$HOME/.local/lib/code-youtube-bg/server.js"
server_label="com.naoto.code-youtube-bg.server"
node_bin="$(command -v node || true)"
js_path="$app/Contents/Resources/app/out/vs/workbench/workbench.desktop.main.js"
backup_path="$js_path.before-video-bg"
html_path="$app/Contents/Resources/app/out/vs/code/electron-browser/workbench/workbench.html"
html_backup_path="$html_path.before-youtube-bg"
runtime_js_path="$app/Contents/Resources/app/out/vs/code/electron-browser/workbench/code-youtube-bg-runtime.js"
state_path="$user_data/youtube-bg.json"
live_state_path="$user_data/live-state.json"
runtime_marker="code-youtube-bg-embed-runtime.v7"
server_log_path="$user_data/youtube-bg-server.log"
server_err_path="$user_data/youtube-bg-server.err"
server_pid_path="$user_data/youtube-bg-server.pid"
server_plist_path="$user_data/code-youtube-bg-server.plist"

if [[ ! -d "$app" ]]; then
  echo "Code Video BG.app not found: $app" >&2
  exit 1
fi

if [[ ! -f "$js_path" ]]; then
  echo "VS Code workbench JS not found: $js_path" >&2
  exit 1
fi

if [[ ! -f "$html_path" ]]; then
  echo "VS Code workbench HTML not found: $html_path" >&2
  exit 1
fi

if [[ ! -f "$server_path" ]]; then
  echo "Local YouTube iframe wrapper server not found: $server_path" >&2
  exit 1
fi

if [[ ! -x "$node_bin" ]]; then
  echo "node not found in PATH" >&2
  exit 1
fi

mkdir -p "$user_data" "$extensions_dir"

target_meta="$("$node_bin" - "$input" <<'NODE'
const input = process.argv[2];

function isVideoId(value) {
  return /^[A-Za-z0-9_-]{11}$/.test(value || '');
}

function isPlaylistId(value) {
  return /^[A-Za-z0-9_-]{12,128}$/.test(value || '');
}

function extractTarget(value) {
  const trimmed = String(value || '').trim();
  if (isVideoId(trimmed)) {
    return {
      kind: 'video',
      videoId: trimmed,
      playlistId: '',
      targetId: trimmed,
      url: `https://www.youtube.com/watch?v=${trimmed}`,
    };
  }
  if (isPlaylistId(trimmed)) {
    return {
      kind: 'playlist',
      videoId: '',
      playlistId: trimmed,
      targetId: trimmed,
      url: `https://www.youtube.com/playlist?list=${trimmed}`,
    };
  }

  let parsed;
  try {
    parsed = new URL(trimmed);
  } catch {
    throw new Error(`Not a YouTube URL or 11-character video ID: ${trimmed}`);
  }

  const host = parsed.hostname.replace(/^www\./, '');
  let videoId = null;
  let playlistId = null;

  if (host === 'youtu.be') {
    videoId = parsed.pathname.split('/').filter(Boolean)[0];
    playlistId = parsed.searchParams.get('list');
  } else if (host.endsWith('youtube.com') || host.endsWith('youtube-nocookie.com')) {
    playlistId = parsed.searchParams.get('list');
    videoId = parsed.searchParams.get('v');
    if (!videoId) {
      const parts = parsed.pathname.split('/').filter(Boolean);
      const marker = parts.findIndex(part => ['embed', 'shorts', 'live'].includes(part));
      if (marker !== -1) videoId = parts[marker + 1];
    }
  } else {
    throw new Error(`Not a YouTube URL or supported ID: ${trimmed}`);
  }

  videoId = isVideoId(videoId) ? videoId : '';
  playlistId = isPlaylistId(playlistId) ? playlistId : '';

  if (playlistId) {
    return {
      kind: 'playlist',
      videoId,
      playlistId,
      targetId: playlistId,
      url: videoId
        ? `https://www.youtube.com/watch?v=${videoId}&list=${playlistId}`
        : `https://www.youtube.com/playlist?list=${playlistId}`,
    };
  }

  if (videoId) {
    return {
      kind: 'video',
      videoId,
      playlistId: '',
      targetId: videoId,
      url: `https://www.youtube.com/watch?v=${videoId}`,
    };
  }

  if (!videoId && !playlistId) {
    throw new Error(`Could not extract a YouTube video ID from: ${trimmed}`);
  }
}

process.stdout.write(JSON.stringify(extractTarget(input)));
NODE
)"

target_kind="$("$node_bin" -e "process.stdout.write(JSON.parse(process.argv[1]).kind)" "$target_meta")"
video_id="$("$node_bin" -e "process.stdout.write(JSON.parse(process.argv[1]).videoId)" "$target_meta")"
playlist_id="$("$node_bin" -e "process.stdout.write(JSON.parse(process.argv[1]).playlistId)" "$target_meta")"
target_id="$("$node_bin" -e "process.stdout.write(JSON.parse(process.argv[1]).targetId)" "$target_meta")"
target_url="$("$node_bin" -e "process.stdout.write(JSON.parse(process.argv[1]).url)" "$target_meta")"

playlist_video_ids_json="[]"
if [[ -n "$playlist_id" ]]; then
  playlist_video_ids_json="$("$node_bin" - "$playlist_id" "$video_id" <<'NODE'
const https = require('https');
const playlistId = process.argv[2];
const preferredVideoId = process.argv[3] || '';

function isVideoId(value) {
  return /^[A-Za-z0-9_-]{11}$/.test(value || '');
}

function fetchText(url) {
  return new Promise((resolve, reject) => {
    https.get(url, {
      headers: {
        'User-Agent': 'code-youtube-bg playlist feed resolver',
      },
    }, res => {
      if (res.statusCode < 200 || res.statusCode >= 300) {
        res.resume();
        reject(new Error(`YouTube playlist feed returned HTTP ${res.statusCode}`));
        return;
      }
      let body = '';
      res.setEncoding('utf8');
      res.on('data', chunk => body += chunk);
      res.on('end', () => resolve(body));
    }).on('error', reject);
  });
}

(async () => {
  const xml = await fetchText(`https://www.youtube.com/feeds/videos.xml?playlist_id=${encodeURIComponent(playlistId)}`);
  const ids = [];
  for (const match of xml.matchAll(/<yt:videoId>([A-Za-z0-9_-]{11})<\/yt:videoId>/g)) {
    if (!ids.includes(match[1])) ids.push(match[1]);
  }
  if (isVideoId(preferredVideoId) && !ids.includes(preferredVideoId)) {
    ids.unshift(preferredVideoId);
  }
  process.stdout.write(JSON.stringify(ids));
})().catch(error => {
  if (isVideoId(preferredVideoId)) {
    process.stdout.write(JSON.stringify([preferredVideoId]));
    return;
  }
  console.error(String(error && error.message || error));
  process.exit(1);
});
NODE
)"
  if [[ -z "$video_id" ]]; then
    video_id="$("$node_bin" -e "const ids=JSON.parse(process.argv[1]); process.stdout.write(ids[0] || '')" "$playlist_video_ids_json")"
  fi
fi

if [[ "$target_kind" == "playlist" && -z "$video_id" ]]; then
  echo "Could not find any videos in playlist: $playlist_id" >&2
  exit 1
fi

opacity="$("$node_bin" - "$opacity" <<'NODE'
const value = Number(process.argv[2]);
if (!Number.isFinite(value) || value < 0 || value > 1) {
  throw new Error('CODE_YOUTUBE_BG_OPACITY must be a number from 0.0 to 1.0');
}
process.stdout.write(String(value));
NODE
)"

if [[ "$audio_enabled" != "0" && "$audio_enabled" != "1" ]]; then
  echo "CODE_YOUTUBE_BG_AUDIO must be 0 or 1" >&2
  exit 1
fi

volume="$("$node_bin" - "$volume" <<'NODE'
const value = Number(process.argv[2]);
if (!Number.isFinite(value) || value < 0 || value > 1) {
  throw new Error('Volume must be a number from 0.0 to 1.0');
}
process.stdout.write(String(value));
NODE
)"

debug_port="$("$node_bin" - "$debug_port" <<'NODE'
const value = Number(process.argv[2]);
if (!Number.isInteger(value) || value < 1024 || value > 65535) {
  throw new Error('CODE_YOUTUBE_BG_DEBUG_PORT must be an integer from 1024 to 65535');
}
process.stdout.write(String(value));
NODE
)"

stop_code_video_bg() {
  osascript -e 'tell application id "com.naoto.CodeVideoBG" to quit' >/dev/null 2>&1 || true
  pkill -TERM -f "$app" 2>/dev/null || true
  pkill -TERM -f "$user_data" 2>/dev/null || true

  for _ in {1..30}; do
    if ! pgrep -f "$app" >/dev/null 2>&1 && ! pgrep -f "$user_data" >/dev/null 2>&1; then
      return 0
    fi
    sleep 0.2
  done

  pkill -KILL -f "$app" 2>/dev/null || true
  pkill -KILL -f "$user_data" 2>/dev/null || true
  sleep 0.5
}

is_code_video_bg_running() {
  if osascript -e 'application id "com.naoto.CodeVideoBG" is running' 2>/dev/null | grep -q true; then
    return 0
  fi

  pgrep -f "$app/Contents/MacOS/Code" >/dev/null 2>&1
}

activate_code_video_bg() {
  osascript \
    -e 'ignoring application responses' \
    -e 'tell application id "com.naoto.CodeVideoBG" to activate' \
    -e 'end ignoring' >/dev/null 2>&1 || true
}

debug_available() {
  curl -fsS "http://127.0.0.1:$debug_port/json/list" >/dev/null 2>&1
}

unlock_youtube_audio() {
  [[ "$audio_enabled" == "1" ]] || return 0

  "$node_bin" - "$debug_port" "$server_port" "$volume" <<'NODE'
const http = require('http');

const debugPort = Number(process.argv[2]);
const serverPort = Number(process.argv[3]);
const volume = Math.max(0, Math.min(1, Number(process.argv[4])));

if (typeof WebSocket !== 'function') {
  process.exit(0);
}

function sleep(ms) {
  return new Promise(resolve => setTimeout(resolve, ms));
}

function getJson(path) {
  return new Promise((resolve, reject) => {
    http.get({ host: '127.0.0.1', port: debugPort, path }, res => {
      let body = '';
      res.setEncoding('utf8');
      res.on('data', chunk => body += chunk);
      res.on('end', () => {
        try {
          resolve(JSON.parse(body));
        } catch (error) {
          reject(error);
        }
      });
    }).on('error', reject);
  });
}

async function evaluate(webSocketDebuggerUrl, expression, userGesture = false) {
  const ws = new WebSocket(webSocketDebuggerUrl);
  let id = 0;
  const pending = new Map();
  ws.onmessage = event => {
    const message = JSON.parse(event.data);
    if (message.id && pending.has(message.id)) {
      pending.get(message.id)(message);
      pending.delete(message.id);
    }
  };
  await new Promise((resolve, reject) => {
    ws.onopen = resolve;
    ws.onerror = reject;
  });
  function send(method, params = {}) {
    const messageId = ++id;
    ws.send(JSON.stringify({ id: messageId, method, params }));
    return new Promise(resolve => pending.set(messageId, resolve));
  }
  await send('Runtime.enable');
  const result = await send('Runtime.evaluate', {
    expression,
    returnByValue: true,
    awaitPromise: true,
    userGesture,
  });
  ws.close();
  return result && result.result && result.result.result && result.result.result.value;
}

(async () => {
  for (let attempt = 0; attempt < 30; attempt += 1) {
    let targets = [];
    try {
      targets = await getJson('/json/list');
    } catch (_) {
      await sleep(500);
      continue;
    }

    const youtube = targets.find(target =>
      target.webSocketDebuggerUrl &&
      (
        String(target.url || '').startsWith('https://www.youtube.com/embed/') ||
        String(target.url || '').startsWith('https://www.youtube-nocookie.com/embed/')
      )
    );
    if (!youtube) {
      await sleep(500);
      continue;
    }

    const expression = `(() => {
      try {
        const player = document.getElementById('movie_player');
        if (player && typeof player.setVolume === 'function') player.setVolume(${Math.round(volume * 100)});
        if (player && typeof player.unMute === 'function') player.unMute();
        if (player && typeof player.playVideo === 'function') player.playVideo();
        const button = document.querySelector('.ytmCuedOverlayPlayButton,.ytp-large-play-button,.ytp-play-button');
        if (button) button.click();
        const video = document.querySelector('video');
        return {
          ok: Boolean(player || button || video),
          state: player && player.getPlayerState && player.getPlayerState(),
          time: video && video.currentTime,
          paused: video && video.paused,
          muted: video && video.muted
        };
      } catch (error) {
        return { ok: false, reason: String(error && error.message || error) };
      }
    })()`;

    await evaluate(youtube.webSocketDebuggerUrl, expression, true);
    await sleep(5000);
    const status = await evaluate(youtube.webSocketDebuggerUrl, `(() => {
      const player = document.getElementById('movie_player');
      const video = document.querySelector('video');
      return {
        ok: Boolean(video && !video.paused && !video.muted && video.currentTime > 0),
        state: player && player.getPlayerState && player.getPlayerState(),
        time: video && video.currentTime,
        paused: video && video.paused,
        muted: video && video.muted
      };
    })()`);

    if (status && status.ok) {
      console.log('YouTube iframe audio unlocked');
      return;
    }
  }
})().catch(() => {});
NODE
}

health_ok() {
  local health_json="$1"
  HEALTH_JSON="$health_json" "$node_bin" - "$target_id" <<'NODE' >/dev/null 2>&1
const expected = process.argv[2];
try {
  const health = JSON.parse(process.env.HEALTH_JSON || '{}');
  process.exit(health.serverVersion === 22 && health.currentTargetId === expected ? 0 : 1);
} catch {
  process.exit(1);
}
NODE
}

start_bg_server() {
  local health=""
  health="$(curl -fsS "http://127.0.0.1:$server_port/health" 2>/dev/null || true)"
  if health_ok "$health"; then
    return 0
  fi

  launchctl bootout "gui/$(id -u)" "$server_plist_path" 2>/dev/null || true
  launchctl remove "$server_label" 2>/dev/null || true
  if [[ -f "$server_pid_path" ]]; then
    local old_server_pid=""
    old_server_pid="$(sed -n '1p' "$server_pid_path" 2>/dev/null || true)"
    if [[ "$old_server_pid" =~ ^[0-9]+$ ]]; then
      kill "$old_server_pid" 2>/dev/null || true
    fi
    rm -f "$server_pid_path"
  fi
  pkill -TERM -f "code-youtube-bg-server .* $server_port" 2>/dev/null || true

  for _ in {1..30}; do
    if ! pgrep -f "code-youtube-bg-server .* $server_port" >/dev/null 2>&1 && ! lsof -nP -iTCP:"$server_port" -sTCP:LISTEN >/dev/null 2>&1; then
      break
    fi
    sleep 0.1
  done

  : > "$server_log_path"
  : > "$server_err_path"

  "$node_bin" - "$server_plist_path" "$server_label" "$node_bin" "$server_path" "$target_id" "$server_port" "$live_state_path" "$server_log_path" "$server_err_path" <<'NODE'
const fs = require('fs');
const [
  plistPath,
  label,
  nodeBin,
  serverPath,
  targetId,
  serverPort,
  liveStatePath,
  serverLogPath,
  serverErrPath,
] = process.argv.slice(2);

function esc(value) {
  return String(value)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&apos;');
}

function stringArray(values) {
  return `<array>\n${values.map(value => `\t\t<string>${esc(value)}</string>`).join('\n')}\n\t</array>`;
}

function envDict(values) {
  return `<dict>\n${Object.entries(values).map(([key, value]) => `\t\t<key>${esc(key)}</key>\n\t\t<string>${esc(value)}</string>`).join('\n')}\n\t</dict>`;
}

const xml = `<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
\t<key>Label</key>
\t<string>${esc(label)}</string>
\t<key>ProgramArguments</key>
\t${stringArray([nodeBin, serverPath, targetId, serverPort])}
\t<key>EnvironmentVariables</key>
\t${envDict({
  CODE_YOUTUBE_BG_STATE_PATH: liveStatePath,
})}
\t<key>RunAtLoad</key>
\t<true/>
\t<key>ProcessType</key>
\t<string>Background</string>
\t<key>StandardOutPath</key>
\t<string>${esc(serverLogPath)}</string>
\t<key>StandardErrorPath</key>
\t<string>${esc(serverErrPath)}</string>
</dict>
</plist>
`;
fs.writeFileSync(plistPath, xml, 'utf8');
NODE

  if ! launchctl bootstrap "gui/$(id -u)" "$server_plist_path" 2>>"$server_err_path"; then
    nohup /usr/bin/env CODE_YOUTUBE_BG_STATE_PATH="$live_state_path" \
      "$node_bin" "$server_path" "$target_id" "$server_port" \
      >>"$server_log_path" 2>>"$server_err_path" </dev/null &
    local new_server_pid="$!"
    printf '%s\n' "$new_server_pid" > "$server_pid_path"
    disown "$new_server_pid" 2>/dev/null || true
  else
    rm -f "$server_pid_path"
  fi

  local server_ready=0
  for _ in {1..120}; do
    health="$(curl -fsS "http://127.0.0.1:$server_port/health" 2>/dev/null || true)"
    if health_ok "$health"; then
      server_ready=1
      break
    fi
    sleep 0.1
  done

  if [[ "$server_ready" != "1" ]]; then
    echo "Failed to start local YouTube iframe wrapper server on port $server_port" >&2
    tail -n 50 "$server_log_path" >&2 || true
    tail -n 50 "$server_err_path" >&2 || true
    exit 1
  fi
}

patch_result="$("$node_bin" - "$input" "$opacity" "$audio_enabled" "$volume" "$server_port" "$js_path" "$backup_path" "$html_path" "$html_backup_path" "$runtime_js_path" "$state_path" "$live_state_path" "$target_kind" "$video_id" "$playlist_id" "$target_id" "$playlist_video_ids_json" "$runtime_marker" <<'NODE'
const fs = require('fs');
const path = require('path');

const [input, opacityText, audioEnabledText, volumeText, serverPortText, jsPath, backupPath, htmlPath, htmlBackupPath, runtimeJsPath, statePath, liveStatePath, targetKind, videoId, playlistId, targetId, playlistVideoIdsText, runtimeMarker] = process.argv.slice(2);
const opacity = Number(opacityText);
const muted = audioEnabledText !== '1';
const volume = Number(volumeText);
const serverPort = Number(serverPortText);
const playlistVideoIds = JSON.parse(playlistVideoIdsText || '[]');

if (!Number.isFinite(opacity) || opacity < 0 || opacity > 1) {
  throw new Error(`Invalid CODE_YOUTUBE_BG_OPACITY: ${opacityText}`);
}

if (!Number.isFinite(volume) || volume < 0 || volume > 1) {
  throw new Error(`Invalid volume: ${volumeText}`);
}

if (!Number.isInteger(serverPort) || serverPort < 1024 || serverPort > 65535) {
  throw new Error(`Invalid CODE_YOUTUBE_BG_PORT: ${serverPortText}`);
}

function patchWorkbenchHtml() {
  const originalHtml = fs.readFileSync(htmlPath, 'utf8');
  if (!fs.existsSync(htmlBackupPath)) {
    fs.copyFileSync(htmlPath, htmlBackupPath);
  }

  const localOrigin = `http://127.0.0.1:${serverPort}`;
  const runtimeScript = '<script src="./code-youtube-bg-runtime.js"></script>';
  const workbenchScript = '<script src="./workbench.js" type="module"></script>';
  let html = originalHtml;
  html = html.replace(
    /connect-src\s+([\s\S]*?)\s+;/,
    match => match.includes(localOrigin) ? match : match.replace(/\s+;/, `\n\t\t\t\t\t${localOrigin}\n\t\t\t\t;`)
  );
  html = html.replace(
    /frame-src\s+([\s\S]*?)\s+;/,
    match => match.includes(localOrigin) ? match : match.replace(/\s+;/, `\n\t\t\t\t\t${localOrigin}\n\t\t\t\t;`)
  );

  if (!html.includes(runtimeScript)) {
    if (!html.includes(workbenchScript)) {
      throw new Error('Could not find VS Code workbench script tag in workbench.html');
    }
    html = html.replace(workbenchScript, `${runtimeScript}\n\t${workbenchScript}`);
  }

  if (html !== originalHtml) {
    fs.writeFileSync(htmlPath, html, 'utf8');
  }

  return html !== originalHtml;
}

function runtimeSource() {
  const stateUrl = `http://127.0.0.1:${serverPort}/state.json`;
  return `(function(){
var RUNTIME=${JSON.stringify(runtimeMarker)};
var stateUrl=${JSON.stringify(stateUrl)};
var debugUrl=stateUrl.replace(/\\/state\\.json(?:\\?.*)?$/,'/debug');
var wrap=null;
var frame=null;
var style=null;
var currentKey='';
function clamp(n,min,max){return Math.min(max,Math.max(min,n));}
function ensure(){
  if(!style||!style.isConnected){
    style=document.getElementById('code-youtube-bg-embed-css');
  }
  if(!style){
    style=document.createElement('style');
    style.id='code-youtube-bg-embed-css';
    document.head.appendChild(style);
  }
  if(!wrap||!wrap.isConnected){
    wrap=document.getElementById('vscbg-wrap');
  }
  if(!wrap){
    wrap=document.createElement('div');
    wrap.id='vscbg-wrap';
    wrap.style.cssText='position:fixed;inset:0;width:100vw;height:100vh;z-index:0;pointer-events:none;overflow:hidden;background:#000;';
    document.body.insertBefore(wrap,document.body.firstChild);
  }
}
function liveCss(op){
  return [
    'html,body{background:#000!important}',
    'body{position:relative!important}',
    '#vscbg-wrap{z-index:0!important}',
    '.monaco-workbench{position:relative!important;z-index:1!important;opacity:'+op+'!important}'
  ].join('');
}
function wrapperSrc(state,key){
  var params=new URLSearchParams({
    kind:String(state.kind||state.type||'video'),
    v:String(state.videoId||''),
    list:String(state.playlistId||''),
    token:key,
    muted:state.muted===false?'0':'1',
    volume:String(clamp(Number(state.volume)||0,0,1)),
    _:String(Date.now())
  });
  return 'http://127.0.0.1:'+${JSON.stringify(serverPort)}+'/?'+params.toString();
}
function report(reason,state){
  try{
    fetch(debugUrl,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({
      runtime:RUNTIME,
      reason:reason||'tick',
      key:currentKey,
      kind:state&&state.kind||'',
      videoId:state&&state.videoId||'',
      playlistId:state&&state.playlistId||'',
      playlistCount:state&&state.playlistVideoIds&&state.playlistVideoIds.length||0,
      muted:!(state&&state.muted===false),
      volume:state&&state.volume,
      receivedAt:new Date().toISOString()
    }),keepalive:true}).catch(function(){});
  }catch(e){}
}
function applyState(state){
  if(!state||!(state.videoId||state.playlistId))return;
  ensure();
  var op=Number(state.opacity);
  if(!isFinite(op))op=0.75;
  op=clamp(op,0,1);
  style.textContent=liveCss(op);
  report('state-applied',state);
  var key=String(state.mediaToken||state.updatedAt||state.playlistId||state.videoId);
  if(frame&&currentKey===key){
    report('unchanged',state);
    return;
  }
  var next=document.createElement('iframe');
  next.id='code-youtube-bg-embed-frame';
  next.title='YouTube embed background';
  next.allow='autoplay; encrypted-media; picture-in-picture; fullscreen';
  next.referrerPolicy='strict-origin-when-cross-origin';
  next.style.cssText='position:absolute;inset:0;width:100%;height:100%;border:0;opacity:0;transition:opacity .18s linear;pointer-events:none;background:#000;';
  next.src=wrapperSrc(state,key);
  next.addEventListener('load',function(){
    report('iframe-loaded',state);
    next.style.opacity='1';
    var old=frame;
    frame=next;
    currentKey=key;
    if(old&&old!==next){
      old.style.opacity='0';
      setTimeout(function(){try{old.remove();}catch(e){}},220);
    }
  },{once:true});
  wrap.appendChild(next);
}
function poll(){
  fetch(stateUrl+'?_='+Date.now(),{cache:'no-store'})
    .then(function(r){return r.ok?r.json():null;})
    .then(applyState)
    .catch(function(){});
}
function start(){
  if(window.__codeYoutubeEmbedBgStarted)return;
  window.__codeYoutubeEmbedBgStarted=true;
  ensure();
  poll();
  setInterval(poll,2000);
  window.addEventListener('focus',poll);
}
if(document.body){start();}
else{document.addEventListener('DOMContentLoaded',start);}
})();`;
}

const htmlChanged = patchWorkbenchHtml();

let jsChanged = false;
if (fs.existsSync(backupPath)) {
  const originalJs = fs.readFileSync(backupPath, 'utf8');
  const currentJs = fs.existsSync(jsPath) ? fs.readFileSync(jsPath, 'utf8') : '';
  if (currentJs !== originalJs) {
    fs.writeFileSync(jsPath, originalJs, 'utf8');
    jsChanged = true;
  }
}

const runtime = runtimeSource();
const currentRuntime = fs.existsSync(runtimeJsPath) ? fs.readFileSync(runtimeJsPath, 'utf8') : '';
const runtimeChanged = currentRuntime !== runtime;
if (runtimeChanged) {
  fs.writeFileSync(runtimeJsPath, runtime, 'utf8');
}

const mediaToken = `${Date.now()}-${targetId}`;
const commonState = {
  type: 'embed',
  kind: targetKind,
  input,
  videoId,
  playlistId,
  playlistVideoIds,
  targetId,
  mediaToken,
  muted,
  volume,
  opacity,
  serverPort,
  stateUrl: `http://127.0.0.1:${serverPort}/state.json`,
  wrapperUrl: `http://127.0.0.1:${serverPort}/`,
  updatedAt: new Date().toISOString(),
};

fs.mkdirSync(path.dirname(statePath), { recursive: true });
fs.writeFileSync(statePath, JSON.stringify(commonState, null, 2) + '\n');
fs.writeFileSync(liveStatePath, JSON.stringify(commonState, null, 2) + '\n');

console.log(`needs_restart=${jsChanged || runtimeChanged ? 1 : 0}`);
console.log(`html_changed=${htmlChanged ? 1 : 0}`);
console.log(`YouTube embed background set for ${targetId}`);
NODE
)"

printf '%s\n' "$patch_result" | sed '/^needs_restart=/d;/^html_changed=/d'
needs_restart="$(printf '%s\n' "$patch_result" | sed -n 's/^needs_restart=//p' | tail -n 1)"
html_changed="$(printf '%s\n' "$patch_result" | sed -n 's/^html_changed=//p' | tail -n 1)"

start_bg_server

if [[ "$needs_restart" == "1" || "$html_changed" == "1" ]]; then
  codesign --force --deep --sign - "$app" >/dev/null
fi

app_running=0
if is_code_video_bg_running; then
  app_running=1
fi

if [[ "$needs_restart" == "1" || "$html_changed" == "1" ]]; then
  stop_code_video_bg
  app_running=0
  rm -rf "$user_data/CachedData" "$user_data/Code Cache" 2>/dev/null || true
  start_bg_server
fi

if [[ "$audio_enabled" == "1" && "$app_running" == "1" ]] && ! debug_available; then
  stop_code_video_bg
  app_running=0
fi

if [[ "$app_running" == "0" ]]; then
  open -na "$app" --args \
    --user-data-dir "$user_data" \
    --extensions-dir "$extensions_dir" \
    --autoplay-policy=no-user-gesture-required \
    --password-store=basic \
    --use-mock-keychain \
    --remote-debugging-port="$debug_port" \
    --new-window "$HOME"
  sleep 3
  echo "Code Video BG launched with YouTube embed background: $target_url"
else
  echo "Code Video BG YouTube embed background updated without restart: $target_url"
fi

activate_code_video_bg
unlock_youtube_audio
