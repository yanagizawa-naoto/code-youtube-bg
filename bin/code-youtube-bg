  --user-data-dir "$user_data" \
  --extensions-dir "$extensions_dir" \
  --password-store=basic \
  --use-mock-keychain \
  --new-window "$HOME"

sleep 3
activate_code_video_bg

echo "Code Video BG launched with YouTube background: $input"
